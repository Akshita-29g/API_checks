# ============================================
# Romantic Website — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# Server
PORT=3000

# WhatsApp Cloud API (Meta Business)
# Get these from: https://developers.facebook.com → Your App → WhatsApp → API Setup
WA_ACCESS_TOKEN=your_permanent_access_token_here
WA_PHONE_NUMBER_ID=your_phone_number_id_here
WA_RECIPIENT_PHONE=919876543210
